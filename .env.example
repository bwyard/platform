# ============================================================
# breeyard environment variables
# Copy to .env and fill in values
# ============================================================

# App
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://breeyard:changeme@localhost:5432/breeyard

# Redis
REDIS_URL=redis://:changeme@localhost:6379

# Auth
BETTER_AUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3002
CORS_ORIGINS=http://localhost:5173,http://localhost:3002
# Production only: set to .8ofwands.com to share session cookie across subdomains.
# Leave unset for local dev — localhost ports share cookies automatically.
COOKIE_DOMAIN=

# Mail (local dev — Mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@breeyard.dev

# Storage (S3-compatible)
STORAGE_ENDPOINT=
STORAGE_REGION=eu-west-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=breeyard-media

# Internal API URL — server-side fetch in apps/web and apps/admin load functions
INTERNAL_API_URL=http://localhost:3010

# Public API URL — browser-side auth client in apps/admin
PUBLIC_API_URL=http://localhost:3010
