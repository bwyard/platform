{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@breeyard/shared": ["./packages/core/shared/src/index.ts"],
      "@breeyard/config": ["./packages/core/config/src/index.ts"],
      "@breeyard/theme": ["./packages/core/theme/src/index.ts"],
      "@breeyard/ui": ["./packages/core/ui/src/index.ts"],
      "@breeyard/auth": ["./packages/core/auth/src/index.ts"],
      "@breeyard/database": ["./packages/core/database/src/index.ts"],
      "@breeyard/mail": ["./packages/core/mail/src/index.ts"],
      "@breeyard/storage": ["./packages/core/storage/src/index.ts"],
      "@breeyard/validation": ["./packages/core/validation/src/index.ts"],
      "@breeyard/crypto": ["./packages/core/crypto/src/index.ts"],
      "@breeyard/hooks": ["./packages/core/hooks/src/index.ts"],
      "@breeyard/seo": ["./packages/core/seo/src/index.ts"],
      "@breeyard/test-utils": ["./packages/core/test-utils/src/index.ts"],
      "@breeyard/logging": ["./packages/infra/logging/src/index.ts"],
      "@breeyard/queue": ["./packages/infra/queue/src/index.ts"],
      "@breeyard/cache": ["./packages/infra/cache/src/index.ts"],
      "@breeyard/rate-limit": ["./packages/infra/rate-limit/src/index.ts"],
      "@breeyard/metrics": ["./packages/infra/metrics/src/index.ts"],
      "@breeyard/health": ["./packages/infra/health/src/index.ts"],
      "@breeyard/errors": ["./packages/infra/errors/src/index.ts"],
      "@breeyard/pwa": ["./packages/cms/pwa/src/index.ts"],
      "@breeyard/messaging": ["./packages/client-portal/messaging/src/index.ts"],
      "@breeyard/notifications": ["./packages/client-portal/notifications/src/index.ts"],
      "@breeyard/session": ["./packages/client-portal/session/src/index.ts"],
      "@breeyard/kv": ["./packages/client-portal/kv/src/index.ts"],
      "@breeyard/audit": ["./packages/ops/audit/src/index.ts"],
      "@breeyard/analytics": ["./packages/ops/analytics/src/index.ts"],
      "@breeyard/payments": ["./packages/extended/payments/src/index.ts"],
      "@breeyard/gdpr": ["./packages/extended/gdpr/src/index.ts"],
      "@breeyard/maintenance": ["./packages/extended/maintenance/src/index.ts"],
      "@breeyard/search": ["./packages/extended/search/src/index.ts"],
      "@breeyard/roles": ["./packages/extended/roles/src/index.ts"],
      "@breeyard/i18n": ["./packages/extended/i18n/src/index.ts"],
      "@breeyard/flags": ["./packages/extended/flags/src/index.ts"]
    }
  }
}
