{
  "name": "breeyard",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run-many -t dev",
    "test": "nx run-many -t test",
    "test:coverage": "nx run-many -t test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:local": "node --env-file=.env.test node_modules/.bin/playwright test",
    "typecheck": "pnpm --filter './packages/**' run build && pnpm -r --if-present run typecheck",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint:fix",
    "format": "prettier --write \"**/*.{ts,js,json,css,md,svelte}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,css,md,svelte}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "10.4.0",
    "@nx/eslint": "22.7.2",
    "@nx/js": "22.7.2",
    "@nx/node": "22.7.2",
    "@nx/playwright": "22.7.2",
    "@nx/vitest": "22.7.2",
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "5.3.1",
    "@trpc/client": "11.17.0",
    "@trpc/server": "11.17.0",
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.18.0",
    "happy-dom": "^20.8.9",
    "husky": "9.1.7",
    "lint-staged": "17.0.6",
    "nx": "22.7.5",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "4.0.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "svelte-eslint-parser": "1.6.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7"
  },
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  }
}
