{
  "name": "@breeyard/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@breeyard/auth": "workspace:*",
    "@breeyard/config": "workspace:*",
    "@breeyard/database": "workspace:*",
    "@breeyard/errors": "workspace:*",
    "@breeyard/logging": "workspace:*",
    "@breeyard/mail": "workspace:*",
    "@breeyard/shared": "workspace:*",
    "@breeyard/validation": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "better-auth": "1.6.11",
    "drizzle-orm": "0.45.2",
    "fastify": "^5.3.2",
    "postgres": "^3.4.9",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@breeyard/test-utils": "workspace:*",
    "@types/node": "24.12.4",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
