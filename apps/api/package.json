{
  "name": "@breeyard/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@breeyard/auth": "workspace:*",
    "@breeyard/config": "workspace:*",
    "@breeyard/database": "workspace:*",
    "@breeyard/errors": "workspace:*",
    "@breeyard/logging": "workspace:*",
    "@breeyard/mail": "workspace:*",
    "@breeyard/shared": "workspace:*",
    "@breeyard/validation": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "better-auth": "^1.2.8",
    "drizzle-orm": "^0.43.1",
    "fastify": "^5.3.2",
    "postgres": "^3.4.9",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@breeyard/test-utils": "workspace:*",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
